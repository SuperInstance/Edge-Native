{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus-platform.org/schemas/reflex_definition.json",
  "title": "NEXUS Platform - Reflex Definition",
  "description": "JSON schema for reflex behaviors executed by the ESP32 bytecode VM. Reflexes define the 'muscle memory' of the system - fast, deterministic control loops that run independently of the Jetson.",
  "type": "object",
  "required": ["reflex_id", "version", "priority", "inputs", "outputs", "states", "initial_state"],
  "properties": {
    "reflex_id": {
      "type": "string",
      "maxLength": 48,
      "pattern": "^[a-z0-9_]+$"
    },
    "version": { "type": "integer", "minimum": 1 },
    "priority": {
      "type": "integer",
      "minimum": 0,
      "maximum": 4,
      "description": "0=kill-switch, 1=safety, 2=failsafe, 3=primary, 4=background"
    },
    "tick_divisor": {
      "type": "integer",
      "default": 10,
      "description": "Execute every N ticks. At 1kHz base, divisor=10 means 100Hz."
    },
    "description": { "type": "string" },
    "provenance": {
      "type": "object",
      "properties": {
        "source": { "type": "string", "enum": ["human_coded", "ai_generated", "narration", "pattern_discovery", "ab_test_winner"] },
        "captain_id": { "type": "string" },
        "narration": { "type": "string" },
        "pattern_id": { "type": "string" },
        "statistical_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "n_ab_tests_passed": { "type": "integer" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "inputs": {
      "type": "object",
      "description": "Named sensor inputs that this reflex reads.",
      "additionalProperties": {
        "type": "object",
        "required": ["source"],
        "properties": {
          "source": { "type": "string", "enum": ["pin", "var", "derived"] },
          "pin_id": { "type": "string" },
          "field": { "type": "string" },
          "default": { "type": ["number", "boolean", "string"] }
        }
      }
    },
    "outputs": {
      "type": "object",
      "description": "Named actuator outputs that this reflex writes.",
      "additionalProperties": {
        "type": "object",
        "required": ["target"],
        "properties": {
          "target": { "type": "string", "enum": ["pin"] },
          "pin_id": { "type": "string" },
          "field": { "type": "string" }
        }
      }
    },
    "variables": {
      "type": "object",
      "description": "State variables maintained across ticks.",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["float", "int", "uint8", "uint32", "bool"] },
          "default": {}
        },
        "required": ["type"]
      }
    },
    "pid_controllers": {
      "type": "object",
      "description": "PID controller instances used by this reflex.",
      "additionalProperties": {
        "type": "object",
        "required": ["kp", "ki", "kd", "output_min", "output_max"],
        "properties": {
          "kp": { "type": "number" },
          "ki": { "type": "number" },
          "kd": { "type": "number" },
          "output_min": { "type": "number" },
          "output_max": { "type": "number" },
          "integral_limit": { "type": "number" },
          "setpoint": { "type": "string" },
          "input": { "type": "string" }
        }
      }
    },
    "states": {
      "type": "object",
      "description": "State machine states with transitions and actions.",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "loop": {
            "type": "object",
            "properties": {
              "steps": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["type"],
                  "properties": {
                    "type": { "type": "string", "enum": ["pid_compute", "add", "sub", "mul", "clamp", "set", "write", "record_observation", "delay_ms", "emit"] },
                    "controller": { "type": "string" },
                    "output_to": { "type": "string" },
                    "a": {}, "b": {}, "result": {},
                    "target": {}, "var": {},
                    "min": {}, "max": {},
                    "value": {},
                    "event": {}
                  }
                }
              }
            }
          },
          "transitions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["event", "next"],
              "properties": {
                "event": { "type": "string" },
                "next": { "type": "string" },
                "threshold": { "type": "number" },
                "condition": { "type": "string" }
              }
            }
          },
          "actions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "type": "string" },
                "target": {},
                "value": {}
              }
            }
          }
        }
      }
    },
    "initial_state": {
      "type": "string",
      "description": "Name of the state where the reflex begins."
    },
    "triggers": {
      "type": "array",
      "description": "External events that can activate this reflex.",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "conditions": { "type": "array", "items": { "type": "object" } },
          "cooldown_ms": { "type": "integer" }
        }
      }
    },
    "guards": {
      "type": "array",
      "description": "Conditions that suppress reflex execution.",
      "items": {
        "type": "object",
        "properties": {
          "var": { "type": "string" },
          "op": { "type": "string", "enum": ["<", ">", "<=", ">=", "==", "!="] },
          "value": {},
          "action": { "type": "string", "enum": ["suppress", "require_approval", "reduce_authority"] }
        }
      }
    },
    "selftest": {
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["read", "assert", "set", "write", "delay_ms"] },
              "source": { "type": "string" },
              "condition": { "type": "string" },
              "target": { "type": "string" },
              "value": {},
              "timeout_ms": { "type": "integer" }
            }
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "max_memory_bytes": { "type": "integer", "default": 2048 },
        "max_cpu_us_per_cycle": { "type": "integer", "default": 500 },
        "category": { "type": "string" }
      }
    }
  }
}

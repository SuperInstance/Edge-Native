        "replaces": "Failed power converter on node board"
      },
      {
        "part": "AMS1117-3.3 LDO Regulator (SOT-223)",
        "description": "800mA 3.3V linear regulator",
        "quantity": 2,
        "criticality": "low",
        "replaces": "Failed 3.3V LDO on node board"
      }
    ],
    "minimum_recommended_spares": {
      "ESP32_S3_boards": 4,
      "M12_cables": 6,
      "fuses": 30
    }
  }
}

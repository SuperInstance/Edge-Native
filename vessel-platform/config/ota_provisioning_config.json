        "description": "ESP32 node power fuse replacements",
        "quantity": 3,
        "criticality": "low",
        "replaces": "Blown fuses"
      },
      {
        "part": "FTDI FT4232H USB-RS422 Adapter",
        "description": "Quad-port RS-422 USB adapter for Jetson serial ports",
        "quantity": 1,
